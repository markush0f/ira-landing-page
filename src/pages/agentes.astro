---
import Layout from "../layouts/Layout.astro";
import AgentsShowcase from "../components/AgentsShowcase.astro";
---

<Layout>
  <main class="min-h-screen relative overflow-hidden">
    {/* Background Atmosphere */}
    <div class="absolute top-0 left-0 w-full h-full pointer-events-none">
      <div
        class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-[#69e9c4]/10 blur-[120px]"
      >
      </div>
      <div
        class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-[#f3a65f]/10 blur-[120px]"
      >
      </div>
    </div>

    <nav
      class="relative z-50 px-8 py-10 flex justify-between items-center max-w-7xl mx-auto w-full"
    >
      <a
        href="/"
        class="flex items-center space-x-2 text-2xl font-black tracking-tighter text-white group"
      >
        <span
          class="flex h-8 w-8 items-center justify-center rounded-lg bg-white text-black transition-transform duration-300 group-hover:rotate-12"
          >I</span
        >
        <span>IRA <span class="font-light text-[#9cb0a9]">ARCHIVE</span></span>
      </a>
      <div
        class="flex space-x-8 text-[10px] uppercase tracking-[0.3em] text-[#8ea29c]"
      >
        <a href="/" class="transition-colors hover:text-white"
          >Volver al Inicio</a
        >
        <span class="text-white underline underline-offset-8">Agentes</span>
      </div>
    </nav>

    <section class="relative z-10 pt-10">
      <div class="text-center max-w-3xl mx-auto px-4 mb-10">
        <h1
          class="mb-6 text-4xl font-black tracking-tighter text-white md:text-6xl"
        >
          Nuestros <span class="font-serif font-light italic opacity-60">Agentes</span
          >
        </h1>
        <p
          class="text-xs uppercase tracking-widest text-[#9cb0a9] md:text-sm"
        >
          El mismo archivo interactivo, pero sin hidratacion cliente. Mas rapido,
          mas ligero y bastante menos costoso para el navegador.
        </p>
      </div>

      <div class="mx-auto max-w-7xl px-4">
        <AgentsShowcase />
      </div>
    </section>

    <footer class="relative z-10 py-20 border-t border-white/5 text-center">
      <p
        class="text-[10px] uppercase tracking-[0.5em] text-[#7e908a]"
      >
        Protocolo de Agentes // version estatica optimizada
      </p>
    </footer>
  </main>
</Layout>
