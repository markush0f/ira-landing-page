---
import { galleryRowA, galleryRowB } from "../data/home";
---

<section class="relative z-30 overflow-hidden px-6 pb-20 pt-8 md:px-10">
  <div class="content-shell">
    <div class="mb-10 flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
      <div>
        <p class="micro-label">Galeria de anomalias</p>
        <h2 class="mt-5 max-w-5xl font-serif text-4xl leading-[0.97] text-[#f2e8d7] md:text-6xl">
          Escenas que parecen ciencia ficcion, pero ya viven dentro del
          comportamiento de los modelos.
        </h2>
      </div>
      <p class="max-w-lg text-sm leading-7 text-[#9db1aa] md:text-base">
        La galeria mantiene movimiento continuo y hover, pero ya no depende de
        scroll listeners ni de Framer Motion.
      </p>
    </div>
  </div>

  <div class="space-y-6">
    <div class="gallery-strip">
      <div class="gallery-track flex w-max gap-5 pl-6 pr-10 md:pl-10">
        {[...galleryRowA, ...galleryRowA].map((item) => (
          <article
            class="gallery-card group relative h-[22rem] w-[17rem] overflow-hidden rounded-[2rem] border border-white/8 p-5 md:w-[20rem]"
            style={`background: ${item.background}`}
          >
            <div
              class="absolute inset-0 opacity-90 transition duration-700 group-hover:scale-110"
              style={`background: radial-gradient(circle at 18% 20%, ${item.glow}, transparent 30%), radial-gradient(circle at 80% 78%, ${item.glow}, transparent 26%);`}
            >
            </div>
            <div class="absolute left-6 right-6 top-6 flex items-center justify-between">
              <span class="text-[0.65rem] uppercase tracking-[0.3em] text-[#f0e2cf]/70">
                {item.id}
              </span>
              <span
                class="rounded-full border px-3 py-1 text-[0.62rem] uppercase tracking-[0.28em]"
                style={`border-color: ${item.accent}33; color: ${item.accent}; background-color: ${item.accent}14;`}
              >
                {item.tag}
              </span>
            </div>

            <div class="relative z-10 flex h-full flex-col justify-end">
              <h3 class="max-w-[12ch] font-serif text-[2rem] leading-none text-[#f2e8d7] md:text-[2.7rem]">
                {item.title}
              </h3>
              <p class="mt-4 max-w-[28ch] text-sm leading-6 text-[#c8d2cf]">
                {item.copy}
              </p>

              <div class="mt-6 overflow-hidden">
                <div class="gallery-reveal translate-y-6 opacity-0 transition duration-500 group-hover:translate-y-0 group-hover:opacity-100">
                  <span class="text-[0.64rem] uppercase tracking-[0.3em] text-[#f0e2cf]/56">
                    Revelacion
                  </span>
                  <p class="mt-3 text-sm leading-6 text-[#f0e2cf]/92">
                    {item.insight}
                  </p>
                </div>
              </div>
            </div>

            <div
              class="absolute bottom-0 left-0 right-0 h-px opacity-0 transition group-hover:opacity-100"
              style={`background: linear-gradient(90deg, transparent, ${item.accent}, transparent);`}
            >
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="gallery-strip">
      <div class="gallery-track gallery-track-reverse flex w-max gap-5 pl-10 pr-6 md:pl-20">
        {[...galleryRowB, ...galleryRowB].map((item) => (
          <article
            class="gallery-card group relative h-[22rem] w-[17rem] overflow-hidden rounded-[2rem] border border-white/8 p-5 md:w-[20rem]"
            style={`background: ${item.background}`}
          >
            <div
              class="absolute inset-0 opacity-90 transition duration-700 group-hover:scale-110"
              style={`background: radial-gradient(circle at 18% 20%, ${item.glow}, transparent 30%), radial-gradient(circle at 80% 78%, ${item.glow}, transparent 26%);`}
            >
            </div>
            <div class="absolute left-6 right-6 top-6 flex items-center justify-between">
              <span class="text-[0.65rem] uppercase tracking-[0.3em] text-[#f0e2cf]/70">
                {item.id}
              </span>
              <span
                class="rounded-full border px-3 py-1 text-[0.62rem] uppercase tracking-[0.28em]"
                style={`border-color: ${item.accent}33; color: ${item.accent}; background-color: ${item.accent}14;`}
              >
                {item.tag}
              </span>
            </div>

            <div class="relative z-10 flex h-full flex-col justify-end">
              <h3 class="max-w-[12ch] font-serif text-[2rem] leading-none text-[#f2e8d7] md:text-[2.7rem]">
                {item.title}
              </h3>
              <p class="mt-4 max-w-[28ch] text-sm leading-6 text-[#c8d2cf]">
                {item.copy}
              </p>

              <div class="mt-6 overflow-hidden">
                <div class="gallery-reveal translate-y-6 opacity-0 transition duration-500 group-hover:translate-y-0 group-hover:opacity-100">
                  <span class="text-[0.64rem] uppercase tracking-[0.3em] text-[#f0e2cf]/56">
                    Revelacion
                  </span>
                  <p class="mt-3 text-sm leading-6 text-[#f0e2cf]/92">
                    {item.insight}
                  </p>
                </div>
              </div>
            </div>

            <div
              class="absolute bottom-0 left-0 right-0 h-px opacity-0 transition group-hover:opacity-100"
              style={`background: linear-gradient(90deg, transparent, ${item.accent}, transparent);`}
            >
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .gallery-strip {
    overflow: hidden;
  }

  .gallery-track {
    animation: gallery-marquee 38s linear infinite;
  }

  .gallery-track-reverse {
    animation-direction: reverse;
    animation-duration: 44s;
  }

  .gallery-card {
    transition: transform 0.35s ease;
  }

  .gallery-card:hover {
    transform: translateY(-8px) scale(1.01);
  }

  @keyframes gallery-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-track {
      animation: none !important;
    }

    .gallery-card:hover {
      transform: none;
    }
  }
</style>
