---
import SectionIntro from "../ui/SectionIntro.astro";
import { glossary } from "../../data/home";
---

<section class="relative z-30 px-6 pb-24 md:px-10">
  <div class="mx-auto grid max-w-7xl gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <div class="glass-panel rounded-[2rem] p-8 md:p-10">
      <SectionIntro
        eyebrow="Glosario minimo"
        title="Seis palabras para leer mejor cualquier producto con IA."
        description="Si un usuario entiende estos conceptos, ya navega con mucha mas claridad entre promesa, realidad tecnica y riesgo."
        titleClass="max-w-2xl font-serif text-5xl leading-[0.95] text-[#f2e8d7] md:text-6xl"
        descriptionClass="max-w-xl text-base leading-8 text-[#a7bab3]"
      />
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {glossary.map((item) => (
        <article class="rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-5">
          <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/78">
            {item.term}
          </span>
          <p class="mt-3 text-sm leading-7 text-[#c6d2ce]">{item.meaning}</p>
        </article>
      ))}
    </div>
  </div>
</section>
