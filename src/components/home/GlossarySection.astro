---
import SectionIntro from "../ui/SectionIntro.astro";
import { glossary } from "../../data/home";

const glossaryGuides = [
  "Pensar en tokens ayuda a entender por que un texto largo encarece y desplaza otras partes del contexto.",
  "El contexto es memoria de trabajo, no memoria total. Cuando se llena, el sistema simplifica o pierde hilo.",
  "Temperatura alta abre variedad; temperatura baja reduce sorpresa. Es una palanca de estilo y de riesgo.",
  "La alineacion moldea conducta visible, tono y limites operativos. Muchas veces es la diferencia entre demo y producto.",
  "Detectar alucinaciones es clave porque su mayor peligro es precisamente lo convincentes que suenan.",
  "El sesgo no es un bug puntual: es una tendencia sistemica que hay que observar, medir y corregir.",
] as const;
---

<section class="relative z-30 px-6 pb-24 md:px-10">
  <div class="mx-auto grid max-w-7xl gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <div class="glass-panel rounded-[2rem] p-8 md:p-10">
      <SectionIntro
        eyebrow="Glosario minimo"
        title="Seis palabras para leer mejor cualquier producto con IA."
        description="Cada termino ahora se abre para conectar definicion y consecuencia practica. La idea es que el glosario sirva para tomar decisiones, no solo para memorizar vocabulario."
        titleClass="max-w-2xl font-serif text-5xl leading-[0.95] text-[#f2e8d7] md:text-6xl"
        descriptionClass="max-w-xl text-base leading-8 text-[#a7bab3]"
      />
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {glossary.map((item, index) => (
        <details
          class="interactive-details rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-5"
          open={index === 0}
        >
          <summary class="interactive-summary">
            <div>
              <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/78">
                {item.term}
              </span>
            </div>
            <span class="interactive-chevron">+</span>
          </summary>

          <p class="mt-3 text-sm leading-7 text-[#c6d2ce]">{item.meaning}</p>
          <div class="interactive-note mt-4">
            <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#f3a65f]/78">
              Por que importa
            </span>
            <p class="mt-3 text-sm leading-7 text-[#c7d3cf]">{glossaryGuides[index]}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
