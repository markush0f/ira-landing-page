---
import SectionIntro from "../ui/SectionIntro.astro";
import { dossierCards, signalMatrix, tickerItems } from "../../data/home";

const toneBackgrounds = {
  mint: {
    background:
      "linear-gradient(180deg, rgba(10, 30, 31, 0.95), rgba(5, 11, 13, 0.96))",
    glow: "radial-gradient(circle at top left, rgba(105, 233, 196, 0.18), transparent 32%)",
  },
  warm: {
    background:
      "linear-gradient(180deg, rgba(30, 18, 10, 0.95), rgba(7, 9, 10, 0.96))",
    glow: "radial-gradient(circle at top left, rgba(243, 166, 95, 0.18), transparent 32%)",
  },
  blue: {
    background:
      "linear-gradient(180deg, rgba(10, 18, 34, 0.95), rgba(5, 8, 11, 0.96))",
    glow: "radial-gradient(circle at top left, rgba(123, 182, 255, 0.18), transparent 32%)",
  },
} as const;

const dossierGuides = [
  {
    prompt: "Que mirar",
    detail: "La sensacion de intimidad suele nacer de continuidad reciente, no de una memoria profunda y estable.",
  },
  {
    prompt: "Que desconfiar",
    detail: "Una salida impecable no demuestra acceso a hechos; solo demuestra dominio de forma y tono.",
  },
  {
    prompt: "Que asumir",
    detail: "El sistema arrastra la forma en la que ya escribimos y ordenamos el mundo antes de usarlo.",
  },
] as const;
---

<section id="archivo" class="relative z-30 px-6 pb-20 md:px-10">
  <div class="content-shell">
    <div class="overflow-hidden rounded-full border border-white/8 bg-white/[0.03]">
      <div class="marquee-track flex min-w-max items-center gap-6 px-6 py-4">
        {[...tickerItems, ...tickerItems].map((item) => (
          <>
            <span class="text-[0.68rem] uppercase tracking-[0.38em] text-[#c1d4cd]/70">
              {item}
            </span>
            <span class="h-1.5 w-1.5 rounded-full bg-[#7ce7c6]/45" />
          </>
        ))}
      </div>
    </div>

    <div class="mt-10 grid gap-5 xl:grid-cols-[0.82fr_1.18fr]">
      <div class="glass-panel rounded-[2rem] p-8 md:p-10">
        <SectionIntro
          eyebrow="Dossier de apertura"
          title="La IA seduce porque convierte calculo en presencia."
          description="Una buena experiencia visual sobre inteligencia artificial no solo enseña rendimiento. Tambien revela que debajo del asombro hay capas ambiguas: memoria parcial, seguridad teatral y decisiones nacidas de datos que nadie ve."
          titleClass="max-w-xl font-serif text-5xl leading-[0.94] text-[#f2e8d7] md:text-6xl"
          descriptionClass="max-w-xl text-base leading-8 text-[#a9bcb5] md:text-lg"
        />

        <div class="space-y-4">
          {signalMatrix.map((signal, index) => (
            <details
              class="interactive-details rounded-[1.4rem] border border-white/8 bg-white/[0.03] p-5"
              open={index === 0}
            >
              <summary class="interactive-summary">
                <div>
                  <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/78">
                    {signal.label}
                  </span>
                  <p class="mt-3 text-sm leading-7 text-[#d7cab8]/92">{signal.value}</p>
                </div>
                <span class="interactive-chevron">+</span>
              </summary>

              <div class="interactive-note mt-4">
                <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#f3a65f]/78">
                  Lectura guiada
                </span>
                <p class="mt-3 text-sm leading-7 text-[#c7d3cf]">
                  {index === 0 &&
                    "Empieza por lo visible: es la capa que mas rapido convence a un usuario y la que mas facil tapa los limites reales del sistema."}
                  {index === 1 &&
                    "Baja un nivel: aqui vive la maquinaria estadistica que decide tono, probabilidad y continuidad sin hacer evidente su proceso."}
                  {index === 2 &&
                    "La conclusion no es tecnica sino de criterio: entender la IA implica entender por que el lenguaje nos convence tan rapido."}
                </p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {dossierCards.map((card, index) => (
          <details
            class="interactive-details relative overflow-hidden rounded-[1.8rem] border border-white/8 p-6"
            open={index === 0}
            style={`background: ${toneBackgrounds[card.tone].background}`}
          >
            <div
              class="absolute inset-0 opacity-80"
              style={`background: ${toneBackgrounds[card.tone].glow}`}
            />
            <summary class="interactive-summary relative z-10">
              <div>
                <span class="text-[0.68rem] uppercase tracking-[0.32em] text-[#f0e2cf]/70">
                  Indice {card.id}
                </span>
                <h3 class="mt-5 font-serif text-4xl leading-none text-[#f2e8d7]">
                  {card.title}
                </h3>
              </div>
              <span class="interactive-chevron">+</span>
            </summary>

            <div class="relative z-10 mt-4">
              <p class="text-sm leading-7 text-[#c2cfcb]">{card.copy}</p>
              <div class="interactive-note mt-4 bg-black/20">
                <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#7ce7c6]/78">
                  {dossierGuides[index].prompt}
                </span>
                <p class="mt-3 text-sm leading-7 text-[#d5ddd9]">
                  {dossierGuides[index].detail}
                </p>
              </div>
            </div>
          </details>
        ))}

        <div class="glass-panel rounded-[1.8rem] p-6 md:col-span-2 md:p-8">
          <div class="grid gap-6 lg:grid-cols-[0.55fr_1.45fr]">
            <div class="rounded-[1.4rem] border border-white/8 bg-black/20 p-5">
              <span class="text-[0.68rem] uppercase tracking-[0.32em] text-[#7ce7c6]/78">
                Hipotesis
              </span>
              <p class="mt-4 font-serif text-6xl leading-none text-[#f2e8d7]">04</p>
            </div>
            <div>
              <p class="micro-label">Nucleo de la puesta en escena</p>
              <p class="mt-4 font-serif text-4xl leading-tight text-[#f0e2cf] md:text-5xl">
                Lo mas inquietante no es que imite al humano, sino que aprenda a
                imitar nuestra confianza.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
