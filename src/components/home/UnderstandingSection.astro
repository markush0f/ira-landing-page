---
import { limits, mirrors, uses } from "../../data/home";
import InteractiveDetails from "../ui/InteractiveDetails.astro";
import PageSection from "../ui/PageSection.astro";

const mirrorGuides = [
  "La sensacion de continuidad nace de como el sistema reutiliza contexto reciente y mantiene tono.",
  "Llamamos intuicion a una compresion estadistica muy afinada cuando la salida llega rapido y con buena forma.",
  "La verdad no se deduce del estilo. Necesita anclaje en datos, fuentes o herramientas externas.",
] as const;

const limitGuides = [
  "Cuando el sistema no sabe, sigue teniendo presion por responder con plausibilidad.",
  "El sesgo no aparece solo en el contenido: tambien en que voces se vuelven invisibles o menos creibles.",
  "Nos impresiona porque habla como nosotros, no porque piense como nosotros.",
] as const;

const useGuides = [
  "Aqui la IA acelera trabajo repetitivo siempre que haya una persona corrigiendo el resultado final.",
  "Estos casos requieren datos actualizados, validacion y responsabilidad clara sobre cada salida.",
  "El mejor uso nace de pedir mejor, no de asumir magia en el modelo.",
] as const;
---

<PageSection containerClass="grid gap-5 lg:grid-cols-[1.08fr_0.92fr]">
  <div class="glass-panel rounded-[2rem] p-8 md:p-10">
    <p class="micro-label">Lo que parece / lo que ocurre</p>
    <div class="mt-8 space-y-5">
      {mirrors.map((entry, index) => (
        <InteractiveDetails
          class="rounded-[1.5rem] border border-white/8 bg-white/[0.03] p-5"
          open={index === 0}
        >
          <Fragment slot="summary">
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#f3a65f]/80">
                  Superficie
                </span>
                <p class="mt-3 font-serif text-3xl leading-tight text-[#f2e8d7]">
                  {entry.face}
                </p>
              </div>
              <div>
                <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/80">
                  Fondo
                </span>
                <p class="mt-3 text-sm leading-7 text-[#c3d0cb]">{entry.core}</p>
              </div>
            </div>
          </Fragment>

          <Fragment slot="note">
            <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#f3a65f]/78">
              Que revela
            </span>
            <p class="mt-3 text-sm leading-7 text-[#c7d3cf]">{mirrorGuides[index]}</p>
          </Fragment>
        </InteractiveDetails>
      ))}
    </div>
  </div>

  <div class="grid gap-6">
    <div class="glass-panel rounded-[2rem] p-8">
      <p class="micro-label">Por que falla</p>
      <h3 class="mt-6 max-w-lg font-serif text-4xl leading-tight text-[#f2e8d7]">
        La IA no se equivoca porque sea "tonta". Se equivoca porque genera con
        probabilidad, no con acceso garantizado a la verdad.
      </h3>
      <div class="mt-6 space-y-4">
        {limits.map((item, index) => (
          <InteractiveDetails
            class="rounded-[1.4rem] border border-white/8 bg-white/[0.03] p-5"
            open={index === 0}
            bodyClass="mt-3"
          >
            <Fragment slot="summary">
              <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#f3a65f]/78">
                {item.title}
              </span>
            </Fragment>

            <p class="text-sm leading-7 text-[#c3d0cb]">{item.copy}</p>

            <Fragment slot="note">
              <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#7ce7c6]/78">
                En producto
              </span>
              <p class="mt-3 text-sm leading-7 text-[#c7d3cf]">{limitGuides[index]}</p>
            </Fragment>
          </InteractiveDetails>
        ))}
      </div>
    </div>

    <div class="glass-panel rounded-[2rem] p-8">
      <p class="micro-label">Uso inteligente</p>
      <div class="mt-6 space-y-4">
        {uses.map((item, index) => (
          <InteractiveDetails
            class="rounded-[1.4rem] border border-white/8 bg-white/[0.03] p-5"
            open={index === 0}
            bodyClass="mt-3"
          >
            <Fragment slot="summary">
              <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/78">
                {item.title}
              </span>
            </Fragment>

            <p class="text-sm leading-7 text-[#c6d2ce]">{item.points}</p>

            <Fragment slot="note">
              <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#f3a65f]/78">
                Regla practica
              </span>
              <p class="mt-3 text-sm leading-7 text-[#c7d3cf]">{useGuides[index]}</p>
            </Fragment>
          </InteractiveDetails>
        ))}
      </div>
    </div>
  </div>
</PageSection>
