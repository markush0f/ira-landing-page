---
import { limits, mirrors, uses } from "../../data/home";
---

<section class="relative z-30 px-6 pb-24 md:px-10">
  <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1.02fr_0.98fr]">
    <div class="glass-panel rounded-[2rem] p-8 md:p-10">
      <p class="micro-label">Lo que parece / lo que ocurre</p>
      <div class="mt-8 space-y-5">
        {mirrors.map((entry) => (
          <div class="grid gap-4 rounded-[1.5rem] border border-white/8 bg-white/[0.03] p-5 md:grid-cols-2">
            <div>
              <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#f3a65f]/80">
                Superficie
              </span>
              <p class="mt-3 font-serif text-3xl leading-tight text-[#f2e8d7]">
                {entry.face}
              </p>
            </div>
            <div>
              <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/80">
                Fondo
              </span>
              <p class="mt-3 text-sm leading-7 text-[#c3d0cb]">{entry.core}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="grid gap-6">
      <div class="glass-panel rounded-[2rem] p-8">
        <p class="micro-label">Por que falla</p>
        <h3 class="mt-6 max-w-lg font-serif text-4xl leading-tight text-[#f2e8d7]">
          La IA no se equivoca porque sea “tonta”. Se equivoca porque genera con
          probabilidad, no con acceso garantizado a la verdad.
        </h3>
        <div class="mt-6 space-y-4">
          {limits.map((item) => (
            <div class="rounded-[1.4rem] border border-white/8 bg-white/[0.03] p-5">
              <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#f3a65f]/78">
                {item.title}
              </span>
              <p class="mt-3 text-sm leading-7 text-[#c3d0cb]">{item.copy}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="glass-panel rounded-[2rem] p-8">
        <p class="micro-label">Uso inteligente</p>
        <div class="mt-6 space-y-4">
          {uses.map((item) => (
            <div class="rounded-[1.4rem] border border-white/8 bg-white/[0.03] p-5">
              <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/78">
                {item.title}
              </span>
              <p class="mt-3 text-sm leading-7 text-[#c6d2ce]">{item.points}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
