---
import SectionIntro from "../ui/SectionIntro.astro";
import { evaluationPillars, humanCheckpoints } from "../../data/home";
---

<section id="evaluacion" class="relative z-30 px-6 pb-24 md:px-10">
  <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1.02fr_0.98fr]">
    <div class="glass-panel rounded-[2rem] p-8 md:p-10">
      <SectionIntro
        eyebrow="Criterio"
        title="La pregunta correcta no es si la IA parece lista, sino si trabaja bien dentro de limites claros."
        description="Medir una IA obliga a mezclar calidad de salida, coste, tiempo de respuesta y capacidad de correccion. Sin ese marco, la demo engaña."
        titleClass="max-w-3xl font-serif text-5xl leading-[0.95] text-[#f2e8d7] md:text-6xl"
        descriptionClass="max-w-xl text-base leading-8 text-[#a7bab3]"
      />

      <div class="mt-8 space-y-4">
        {evaluationPillars.map((item) => (
          <div class="rounded-[1.5rem] border border-white/8 bg-white/[0.03] p-5">
            <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/78">
              Pilar
            </span>
            <h3 class="mt-3 font-serif text-3xl leading-tight text-[#f2e8d7]">
              {item.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-[#c3d0cb]">{item.copy}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="glass-panel rounded-[2rem] p-8 md:p-10">
      <p class="micro-label">Control humano</p>
      <h3 class="mt-6 max-w-lg font-serif text-4xl leading-tight text-[#f2e8d7]">
        Hay momentos en los que una buena experiencia necesita menos autonomia y mas criterio visible.
      </h3>
      <div class="mt-8 space-y-4">
        {humanCheckpoints.map((item) => (
          <article class="rounded-[1.5rem] border border-white/8 bg-white/[0.03] p-5">
            <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#f3a65f]/78">
              {item.stage}
            </span>
            <p class="mt-3 text-sm leading-7 text-[#c6d2ce]">{item.signal}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
