---
import { responseCycle } from "../../data/home";
import InteractiveDetails from "../ui/InteractiveDetails.astro";
import PageSection from "../ui/PageSection.astro";
import SectionIntro from "../ui/SectionIntro.astro";

const responseSignals = [
  "Si la entrada es ambigua, todo el recorrido arranca torcido.",
  "Aqui se mezcla lo que pides con reglas del sistema y restos de la conversacion.",
  "En esta fase nace tanto la creatividad como la posibilidad de alucinacion.",
  "La forma final puede inspirar confianza aunque el contenido necesite contraste.",
] as const;
---

<PageSection>
  <SectionIntro
    eyebrow="Ciclo de respuesta"
    title="Lo que sucede entre tu pregunta y esa frase que parece tan segura."
    description="Cada fase se puede desplegar para que el usuario vea donde se juega la calidad de la respuesta y donde tambien nace el error."
  />

  <div class="grid gap-4 lg:grid-cols-2 xl:grid-cols-4">
    {responseCycle.map((item, index) => (
      <InteractiveDetails class="glass-panel rounded-[1.8rem] p-6" open={index === 0} bodyClass="mt-5" noteClass="mt-5">
        <Fragment slot="summary">
          <span class="text-[0.68rem] uppercase tracking-[0.32em] text-[#f3a65f]/78">
            Fase {item.step}
          </span>
          <h3 class="mt-5 font-serif text-4xl leading-none text-[#f2e8d7]">
            {item.title}
          </h3>
        </Fragment>

        <p class="text-sm leading-7 text-[#bfd0ca]">{item.copy}</p>

        <Fragment slot="note">
          <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#7ce7c6]/78">
            Observa
          </span>
          <p class="mt-3 text-sm leading-7 text-[#c7d3cf]">{responseSignals[index]}</p>
        </Fragment>
      </InteractiveDetails>
    ))}
  </div>
</PageSection>
