---
import { systemLayers } from "../../data/home";
import InteractiveDetails from "../ui/InteractiveDetails.astro";
import PageSection from "../ui/PageSection.astro";
import SectionIntro from "../ui/SectionIntro.astro";

const layerGuides = [
  "Si esta base es floja, el resto solo maquilla problemas mas profundos.",
  "Aqui se fija la conducta visible. Cambiar instrucciones suele dar mas retorno que tocar UI sin criterio.",
  "Esta capa acerca la IA al presente. Sin ella, el sistema improvisa sobre informacion vieja o insuficiente.",
  "Las herramientas convierten lenguaje en accion, pero tambien multiplican el riesgo si no hay controles.",
  "La memoria mejora continuidad, pero tambien puede exagerar la sensacion de identidad o recuerdo real.",
  "Los guardrails deciden donde frenar, pedir confirmacion o negarse. Son producto y politica al mismo tiempo.",
] as const;
---

<PageSection id="arquitectura">
  <SectionIntro
    eyebrow="Arquitectura real"
    title="Una experiencia con IA no es solo el modelo: es una pila de decisiones tecnicas y de producto."
    description="Las capas ahora se pueden abrir una a una para entender que hace cada pieza y por que el usuario final percibe todo como un unico sistema."
  />

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {systemLayers.map((item, index) => (
      <InteractiveDetails
        class="rounded-[1.7rem] border border-white/8 bg-white/[0.03] p-6"
        open={index === 0}
      >
        <Fragment slot="summary">
          <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#f3a65f]/78">
            {item.label}
          </span>
          <h3 class="mt-4 font-serif text-3xl leading-tight text-[#f2e8d7]">
            {item.title}
          </h3>
        </Fragment>

        <p class="text-sm leading-7 text-[#c3d0cb]">{item.copy}</p>

        <Fragment slot="note">
          <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#7ce7c6]/78">
            Impacto real
          </span>
          <p class="mt-3 text-sm leading-7 text-[#c7d3cf]">{layerGuides[index]}</p>
        </Fragment>
      </InteractiveDetails>
    ))}
  </div>
</PageSection>
