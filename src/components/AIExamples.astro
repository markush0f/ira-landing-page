---
import { aiExperimentNotes, aiExperiments } from "../data/home";
import PageSection from "./ui/PageSection.astro";
---

<PageSection id="ejemplos">
    <div class="mb-10 flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
      <div>
        <p class="micro-label">Ejemplos interactivos</p>
        <h2 class="mt-5 max-w-5xl font-serif text-4xl leading-[0.97] text-[#f2e8d7] md:text-6xl">
          El mismo modelo cambia mucho segun como le hablas.
        </h2>
      </div>
      <p class="max-w-lg text-sm leading-7 text-[#a7bab3] md:text-base">
        Cambia de experimento y observa la diferencia entre un prompt pobre, uno
        contextualizado, uno estructurado y otro que exige limites y validacion.
      </p>
    </div>

    <div class="example-shell relative overflow-hidden rounded-[2.4rem] border border-white/8 bg-[#081215]/70 p-5 md:p-8">
      <div
        class="absolute inset-0"
        style="background: radial-gradient(circle at top left, rgba(105, 233, 196, 0.1), transparent 28%), radial-gradient(circle at bottom right, rgba(243, 166, 95, 0.08), transparent 30%);"
      >
      </div>

      {aiExperiments.map((item, index) => (
        <input
          class="sr-only"
          type="radio"
          name="prompt-experiment"
          id={`experiment-${item.id}`}
          checked={index === 0}
        />
      ))}

      <div class="relative z-10 grid gap-5 xl:grid-cols-[0.72fr_1.28fr]">
        <div>
          <p class="micro-label">Selecciona una version</p>
          <div class="mt-6 space-y-3">
            {aiExperiments.map((item) => (
              <label
                for={`experiment-${item.id}`}
                class={`experiment-tab experiment-tab-${item.id} block cursor-pointer rounded-[1.5rem] border border-white/8 bg-white/[0.02] p-4 text-left transition md:p-5`}
              >
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <span class="text-[0.68rem] uppercase tracking-[0.32em] text-[#7ce7c6]/75">
                      Experimento {item.id}
                    </span>
                    <h3 class="mt-3 text-2xl font-medium text-[#f2e8d7]">{item.title}</h3>
                    <p class="mt-3 text-sm leading-6 text-[#aabbb5]">{item.blurb}</p>
                  </div>
                  <span class="rounded-full border border-white/10 px-3 py-1 text-[0.62rem] uppercase tracking-[0.28em] text-[#d5c7b3]">
                    {item.tag}
                  </span>
                </div>
              </label>
            ))}
          </div>
        </div>

        <div class="glass-panel relative overflow-hidden rounded-[2rem] p-6 md:p-8">
          <div class="scan-line"></div>

          {aiExperiments.map((item) => (
            <article class={`experiment-panel experiment-panel-${item.id}`}>
              <div class="flex flex-col gap-5 border-b border-white/8 pb-6 md:flex-row md:items-end md:justify-between">
                <div>
                  <p class="micro-label">Lectura activa {item.id}</p>
                  <h3 class="mt-4 font-serif text-3xl leading-tight text-[#f2e8d7] md:text-5xl">
                    {item.title}
                  </h3>
                </div>
                <span class="rounded-full border border-[#7ce7c6]/25 bg-[#7ce7c6]/8 px-4 py-2 text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/90">
                  {item.tag}
                </span>
              </div>

              <div class="mt-8 grid gap-4 lg:grid-cols-[0.92fr_1.08fr]">
                <div class="rounded-[1.6rem] border border-white/8 bg-black/20 p-5">
                  <p class="text-[0.68rem] uppercase tracking-[0.32em] text-[#f3a65f]/80">
                    Prompt
                  </p>
                  <p class="mt-4 text-sm leading-7 text-[#f0e2cf]/92">
                    {item.prompt}
                  </p>
                </div>

                <div class="rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-5">
                  <p class="text-[0.68rem] uppercase tracking-[0.32em] text-[#7ce7c6]/80">
                    Salida probable
                  </p>
                  <p class="mt-4 text-sm leading-7 text-[#c7d3cf]">
                    {item.response}
                  </p>
                </div>
              </div>

              <div class="mt-6 rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-5">
                <p class="text-[0.68rem] uppercase tracking-[0.32em] text-[#7ce7c6]/80">
                  Que demuestra
                </p>
                <p class="mt-4 text-base leading-8 text-[#d9ccbc]/90">
                  {item.lesson}
                </p>
              </div>

              <div class="mt-6 flex flex-wrap gap-3">
                {item.signals.map((signal) => (
                  <span class="rounded-full border border-white/10 px-4 py-2 text-[0.68rem] uppercase tracking-[0.28em] text-[#c5d4ce]">
                    {signal}
                  </span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-6 grid gap-4 lg:grid-cols-3">
      {aiExperimentNotes.map((item) => (
        <article class="rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-5">
          <span class="text-[0.68rem] uppercase tracking-[0.3em] text-[#f3a65f]/78">
            Nota
          </span>
          <h3 class="mt-4 font-serif text-3xl leading-tight text-[#f2e8d7]">
            {item.title}
          </h3>
          <p class="mt-4 text-sm leading-7 text-[#c6d2ce]">{item.copy}</p>
        </article>
      ))}
    </div>
</PageSection>

<style>
  .experiment-panel {
    display: none;
    animation: experiment-reveal 0.45s ease;
  }

  #experiment-01:checked ~ div .experiment-tab-01,
  #experiment-02:checked ~ div .experiment-tab-02,
  #experiment-03:checked ~ div .experiment-tab-03,
  #experiment-04:checked ~ div .experiment-tab-04 {
    border-color: rgba(124, 231, 198, 0.45);
    background: rgba(124, 231, 198, 0.1);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.22);
    transform: translateX(6px);
  }

  #experiment-01:checked ~ div .experiment-panel-01,
  #experiment-02:checked ~ div .experiment-panel-02,
  #experiment-03:checked ~ div .experiment-panel-03,
  #experiment-04:checked ~ div .experiment-panel-04 {
    display: block;
  }

  @keyframes experiment-reveal {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .experiment-panel {
      animation: none !important;
    }

    #experiment-01:checked ~ div .experiment-tab-01,
    #experiment-02:checked ~ div .experiment-tab-02,
    #experiment-03:checked ~ div .experiment-tab-03,
    #experiment-04:checked ~ div .experiment-tab-04 {
      transform: none;
    }
  }
</style>
