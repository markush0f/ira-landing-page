---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  eyebrow,
  title,
  description,
  titleClass = "max-w-4xl font-serif text-5xl leading-[0.95] text-[#f2e8d7] md:text-7xl",
  descriptionClass = "max-w-md text-base leading-7 text-[#a7bab3]",
} = Astro.props;
---

<div class="mb-10 flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
  <div>
    <p class="micro-label">{eyebrow}</p>
    <h2 class={`mt-6 ${titleClass}`}>{title}</h2>
  </div>
  {description && <p class={descriptionClass}>{description}</p>}
</div>
