---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  eyebrow,
  title,
  description,
  titleClass = "max-w-5xl font-serif text-4xl leading-[0.97] text-[#f2e8d7] md:text-6xl",
  descriptionClass = "max-w-lg text-sm leading-7 text-[#a7bab3] md:text-base",
} = Astro.props;
---

<div class="mb-8 flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
  <div>
    <p class="micro-label">{eyebrow}</p>
    <h2 class={`mt-6 ${titleClass}`}>{title}</h2>
  </div>
  {description && <p class={descriptionClass}>{description}</p>}
</div>
