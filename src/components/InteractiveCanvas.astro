---
import { heroObservationLines, heroPulseCards } from "../data/home";
---

<section class="relative overflow-hidden px-6 py-20 md:px-10 lg:py-24">
  <div
    class="absolute inset-0"
    style="background: radial-gradient(circle at center, rgba(105, 233, 196, 0.08), transparent 26%), radial-gradient(circle at 76% 22%, rgba(243, 166, 95, 0.1), transparent 20%);"
  >
  </div>
  <div class="ambient-grid absolute inset-0 opacity-40"></div>
  <div class="hero-aura hero-aura-main absolute left-1/2 top-[14%] h-[32rem] w-[32rem] -translate-x-1/2 rounded-full bg-[#69e9c4]/10 blur-3xl md:h-[44rem] md:w-[44rem]"></div>
  <div class="hero-aura hero-aura-warm absolute bottom-[5%] right-[8%] h-64 w-64 rounded-full bg-[#f3a65f]/10 blur-3xl md:h-80 md:w-80"></div>
  <div class="hero-aura hero-aura-cold absolute left-[8%] top-[62%] h-48 w-48 rounded-full bg-[#9cd0ff]/6 blur-3xl md:h-72 md:w-72"></div>

  <div class="pointer-events-none absolute left-1/2 top-[44%] h-[26rem] w-[26rem] -translate-x-1/2 -translate-y-1/2 opacity-80 md:h-[40rem] md:w-[40rem]">
    <div class="absolute inset-0 rounded-full border border-[#d7efe7]/10 shadow-[0_0_120px_rgba(105,233,196,0.08)]"></div>
    <div class="hero-orbit hero-orbit-slow absolute inset-[12%] rounded-full border border-dashed border-[#d7efe7]/12"></div>
    <div class="hero-orbit hero-orbit-reverse absolute inset-[28%] rounded-full border border-[#69e9c4]/25"></div>
    <div class="hero-core absolute left-1/2 top-1/2 h-28 w-28 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#69e9c4]/12 blur-2xl md:h-40 md:w-40"></div>
    <div class="absolute left-1/2 top-1/2 h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#f2e8d7] shadow-[0_0_30px_rgba(242,232,215,0.6)]"></div>
  </div>

  <div class="content-shell relative z-20 grid w-full gap-10 xl:grid-cols-[1.14fr_0.86fr] xl:items-center">
    <div class="max-w-4xl">
      <p class="micro-label">Archivo de frontera // la parte invisible de la IA</p>
      <h1 class="mt-7 max-w-6xl text-[15vw] font-medium leading-[0.9] tracking-[-0.055em] text-[#f2e8d7] sm:text-[4.8rem] lg:text-[6.4rem]">
        La interfaz solo enseña la
        <span class="block pl-[0.14em] font-serif text-[0.92em] italic text-[#7ce7c6]">
          superficie.
        </span>
      </h1>
      <p class="mt-6 max-w-3xl text-base leading-7 text-[#b6c8c1] md:text-lg">
        La inteligencia artificial generativa no piensa como un ser humano:
        predice, recombina y simula continuidad a partir de enormes cantidades
        de lenguaje. Aun asi, cuando el resultado esta bien presentado, puede
        parecer intuicion, memoria o incluso criterio propio.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#fundamentos"
          class="rounded-full border border-[#7ce7c6]/45 bg-[#7ce7c6]/12 px-6 py-3 text-sm uppercase tracking-[0.24em] text-[#f2e8d7] transition hover:border-[#7ce7c6]/70 hover:bg-[#7ce7c6]/18"
        >
          Entender la base
        </a>
        <a
          href="#archivo"
          class="rounded-full border border-white/12 px-6 py-3 text-sm uppercase tracking-[0.24em] text-[#d9cdbf] transition hover:border-white/25 hover:bg-white/4"
        >
          Ver capas ocultas
        </a>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        {heroPulseCards.map((card) => (
          <div class="glass-panel rounded-[1.4rem] p-4">
            <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#7ce7c6]/80">
              {card.title}
            </span>
            <p class="mt-3 text-sm leading-6 text-[#9fb2ab]">{card.copy}</p>
          </div>
        ))}
      </div>
    </div>

    <aside class="glass-panel relative overflow-hidden rounded-[2rem] p-6 md:p-7">
      <div class="scan-line"></div>
      <p class="micro-label">Panel de observacion</p>
      <h2 class="mt-5 max-w-xl font-serif text-3xl leading-tight text-[#f2e8d7] md:text-[2.7rem]">
        Una maquina puede sonar segura incluso cuando esta improvisando.
      </h2>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-[#afc1bb] md:text-base">
        La fascinacion empieza cuando el calculo se vuelve presencia. La duda
        empieza cuando olvidamos que esa presencia esta ensamblada, capa por capa,
        a partir de datos humanos.
      </p>

      <div class="mt-8 rounded-[1.6rem] border border-white/8 bg-black/20 p-5">
        {heroObservationLines.map((line, index) => (
          <div
            class={`flex flex-col gap-2 py-4 md:flex-row md:items-start md:justify-between ${
              index < heroObservationLines.length - 1 ? "border-b border-white/8" : ""
            }`}
          >
            <span class="text-[0.7rem] uppercase tracking-[0.32em] text-[#7ce7c6]/80">
              {line.label}
            </span>
            <span class="max-w-sm text-sm leading-6 text-[#d7c9b6]/90">
              {line.value}
            </span>
          </div>
        ))}
      </div>

      <div class="mt-6 rounded-[1.6rem] border border-white/8 bg-white/[0.03] p-5">
        <p class="text-[0.7rem] uppercase tracking-[0.32em] text-[#7ce7c6]/80">
          Lo importante
        </p>
        <p class="mt-3 text-sm leading-7 text-[#c3d0cb]">
          Cuanto mas natural suena una respuesta, mas facil es olvidar que sigue
          siendo una salida probabilistica. Por eso una buena interfaz sobre IA
          no solo deslumbra: tambien aclara como funciona y donde puede fallar.
        </p>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero-orbit {
    animation: hero-spin 32s linear infinite;
  }

  .hero-orbit-slow {
    animation-duration: 34s;
  }

  .hero-orbit-reverse {
    animation-direction: reverse;
    animation-duration: 22s;
  }

  .hero-core {
    animation: hero-pulse 6s ease-in-out infinite;
  }

  .hero-aura {
    animation: aura-drift 14s ease-in-out infinite alternate;
  }

  .hero-aura-warm {
    animation-duration: 18s;
  }

  .hero-aura-cold {
    animation-duration: 16s;
  }

  @keyframes hero-spin {
    from {
      transform: rotate(0deg);
    }

    to {
      transform: rotate(360deg);
    }
  }

  @keyframes hero-pulse {
    0%,
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.35;
    }

    50% {
      transform: translate(-50%, -50%) scale(1.08);
      opacity: 0.6;
    }
  }

  @keyframes aura-drift {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }

    to {
      transform: translate3d(2%, -2%, 0) scale(1.06);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-orbit,
    .hero-core,
    .hero-aura {
      animation: none !important;
    }
  }
</style>
