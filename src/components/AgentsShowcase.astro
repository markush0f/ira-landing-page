---
import { caseFiles } from "../data/home";
---

<div class="showcase-shell relative overflow-hidden rounded-[2.4rem] border border-white/8 bg-[#081215]/70 p-5 md:p-8">
  <div
    class="absolute inset-0"
    style="background: radial-gradient(circle at top right, rgba(105, 233, 196, 0.12), transparent 28%), radial-gradient(circle at bottom left, rgba(243, 166, 95, 0.1), transparent 30%);"
  >
  </div>

  {caseFiles.map((entry, index) => (
    <input
      class="sr-only"
      type="radio"
      name="case-file"
      id={`case-${entry.id}`}
      checked={index === 0}
    />
  ))}

  <div class="relative z-10 grid gap-6 xl:grid-cols-[0.84fr_1.16fr]">
    <div>
      <p class="micro-label">Expedientes sellados</p>
      <h3 class="mt-5 max-w-lg font-serif text-4xl leading-tight text-[#f2e8d7] md:text-5xl">
        Elige un fenomeno y abre su mecanismo interno.
      </h3>
      <p class="mt-4 max-w-md text-base leading-7 text-[#a7bab3]">
        Cada archivo destapa una ilusion distinta: memoria, verdad, sesgo o
        consciencia. Se resuelve con HTML y CSS, sin enviar logica al navegador.
      </p>

      <div class="mt-8 space-y-3">
        {caseFiles.map((entry) => (
          <label
            for={`case-${entry.id}`}
            class={`case-tab case-tab-${entry.id} block cursor-pointer rounded-[1.5rem] border border-white/8 bg-white/[0.02] p-4 text-left transition md:p-5`}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="text-[0.68rem] uppercase tracking-[0.32em] text-[#7ce7c6]/75">
                  Caso {entry.id}
                </span>
                <h4 class="mt-3 text-2xl font-medium text-[#f2e8d7]">{entry.title}</h4>
                <p class="mt-3 max-w-md text-sm leading-6 text-[#aabbb5]">
                  {entry.blurb}
                </p>
              </div>
              <span class="rounded-full border border-white/10 px-3 py-1 text-[0.62rem] uppercase tracking-[0.28em] text-[#d5c7b3]">
                {entry.tag}
              </span>
            </div>
          </label>
        ))}
      </div>
    </div>

    <div class="glass-panel relative overflow-hidden rounded-[2rem] p-6 md:p-8">
      <div class="scan-line"></div>

      {caseFiles.map((entry) => (
        <article class={`case-panel case-panel-${entry.id}`}>
          <div class="flex flex-col gap-5 border-b border-white/8 pb-6 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="micro-label">Expediente activo {entry.id}</p>
              <h3 class="mt-5 font-serif text-4xl leading-tight text-[#f2e8d7] md:text-6xl">
                {entry.title}
              </h3>
            </div>
            <span class="rounded-full border border-[#7ce7c6]/25 bg-[#7ce7c6]/8 px-4 py-2 text-[0.68rem] uppercase tracking-[0.3em] text-[#7ce7c6]/90">
              {entry.tag}
            </span>
          </div>

          <p class="mt-6 max-w-3xl text-lg leading-8 text-[#d9ccbc]/90">
            {entry.detail}
          </p>

          <div class="mt-6 rounded-[1.6rem] border border-white/8 bg-black/20 p-5">
            <p class="text-[0.7rem] uppercase tracking-[0.3em] text-[#f3a65f]/80">
              Declaracion del archivo
            </p>
            <p class="mt-3 font-serif text-3xl leading-tight text-[#f0e2cf] md:text-4xl">
              {entry.mantra}
            </p>
          </div>

          <div class="mt-8 grid gap-4 md:grid-cols-3">
            {entry.signals.map((signal) => (
              <div class="rounded-[1.4rem] border border-white/8 bg-white/[0.03] p-5">
                <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#7ce7c6]/80">
                  {signal.label}
                </span>
                <p class="mt-3 text-sm leading-6 text-[#b8cac4]">{signal.value}</p>
              </div>
            ))}
          </div>

          <div class="mt-8 grid gap-4 md:grid-cols-2">
            <div class="rounded-[1.5rem] border border-white/8 bg-[#f3a65f]/[0.06] p-5">
              <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#f3a65f]/80">
                Lo inquietante
              </span>
              <p class="mt-3 text-sm leading-6 text-[#d9ccb9]">{entry.risk}</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/8 bg-[#7ce7c6]/[0.06] p-5">
              <span class="text-[0.68rem] uppercase tracking-[0.28em] text-[#7ce7c6]/80">
                Lo fascinante
              </span>
              <p class="mt-3 text-sm leading-6 text-[#d9ccb9]">{entry.utility}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>

<style>
  .case-panel {
    display: none;
    animation: panel-reveal 0.45s ease;
  }

  #case-01:checked ~ div .case-tab-01,
  #case-02:checked ~ div .case-tab-02,
  #case-03:checked ~ div .case-tab-03,
  #case-04:checked ~ div .case-tab-04 {
    border-color: rgba(124, 231, 198, 0.45);
    background: rgba(124, 231, 198, 0.1);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.22);
    transform: translateX(6px);
  }

  #case-01:checked ~ div .case-panel-01,
  #case-02:checked ~ div .case-panel-02,
  #case-03:checked ~ div .case-panel-03,
  #case-04:checked ~ div .case-panel-04 {
    display: block;
  }

  @keyframes panel-reveal {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-panel {
      animation: none !important;
    }

    #case-01:checked ~ div .case-tab-01,
    #case-02:checked ~ div .case-tab-02,
    #case-03:checked ~ div .case-tab-03,
    #case-04:checked ~ div .case-tab-04 {
      transform: none;
    }
  }
</style>
